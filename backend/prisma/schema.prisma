// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model Department {
  id               String       @id @default(uuid())
  name             String       @unique
  isActive         Boolean      @default(true)
  headId           String?      @unique
  head             User?        @relation("DepartmentHead", fields: [headId], references: [id])
  parentDeptId     String?
  parentDept       Department?  @relation("ParentDepartment", fields: [parentDeptId], references: [id])
  childDepts       Department[] @relation("ParentDepartment")
  users            User[]       @relation("UserDepartment")
  assets           Asset[]
  allocations      Allocation[]
}

enum Role {
  EMPLOYEE
  DEPARTMENT_HEAD
  ASSET_MANAGER
  ADMIN
}

model User {
  id                   String               @id @default(uuid())
  name                 String
  email                String               @unique
  passwordHash         String
  role                 Role                 @default(EMPLOYEE)
  isActive             Boolean              @default(true)
  departmentId         String?
  department           Department?          @relation("UserDepartment", fields: [departmentId], references: [id])
  headedDepartment     Department?          @relation("DepartmentHead")
  allocations          Allocation[]
  bookings             Booking[]
  maintenanceRequests  MaintenanceRequest[] @relation("MaintenanceRequester")
  maintenanceAssigned  MaintenanceRequest[] @relation("MaintenanceTechnician")
}

model AssetCategory {
  id             String  @id @default(uuid())
  name           String  @unique
  warrantyPeriod Int?    // in months
  assets         Asset[]
}

enum AssetStatus {
  AVAILABLE
  ALLOCATED
  RESERVED
  UNDER_MAINTENANCE
  LOST
  RETIRED
  DISPOSED
}

model Asset {
  id               String               @id @default(uuid())
  assetTag         String               @unique // auto-generated e.g. AF-0001
  name             String
  serialNumber     String?
  acquisitionDate  DateTime
  acquisitionCost  Float?
  condition        String
  location         String
  isSharedBookable Boolean              @default(false)
  status           AssetStatus          @default(AVAILABLE)
  categoryId       String
  category         AssetCategory        @relation(fields: [categoryId], references: [id])
  departmentId     String?
  department       Department?          @relation(fields: [departmentId], references: [id])
  allocations      Allocation[]
  bookings         Booking[]
  maintenanceReqs  MaintenanceRequest[]
  auditItems       AuditItem[]
}

enum AllocationStatus {
  REQUESTED
  APPROVED
  RETURNED
  REJECTED
}

model Allocation {
  id                 String           @id @default(uuid())
  assetId            String
  asset              Asset            @relation(fields: [assetId], references: [id])
  userId             String?
  user               User?            @relation(fields: [userId], references: [id])
  departmentId       String?
  department         Department?      @relation(fields: [departmentId], references: [id])
  expectedReturnDate DateTime?
  actualReturnDate   DateTime?
  status             AllocationStatus @default(REQUESTED)
  conditionCheckIn   String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
}

enum BookingStatus {
  UPCOMING
  ONGOING
  COMPLETED
  CANCELLED
}

model Booking {
  id        String        @id @default(uuid())
  assetId   String
  asset     Asset         @relation(fields: [assetId], references: [id])
  userId    String
  user      User          @relation(fields: [userId], references: [id])
  startTime DateTime
  endTime   DateTime
  status    BookingStatus @default(UPCOMING)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

enum MaintenancePriority {
  LOW
  MEDIUM
  HIGH
}

enum MaintenanceStatus {
  PENDING
  APPROVED
  TECHNICIAN_ASSIGNED
  REJECTED
  IN_PROGRESS
  RESOLVED
}

model MaintenanceRequest {
  id          String              @id @default(uuid())
  assetId     String
  asset       Asset               @relation(fields: [assetId], references: [id])
  requesterId String
  requester   User                @relation("MaintenanceRequester", fields: [requesterId], references: [id])
  assignedTechId String?
  assignedTech   User?            @relation("MaintenanceTechnician", fields: [assignedTechId], references: [id])
  issue       String
  priority    MaintenancePriority @default(MEDIUM)
  status      MaintenanceStatus   @default(PENDING)
  photoUrl    String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
}

model AuditCycle {
  id         String      @id @default(uuid())
  name       String
  startDate  DateTime
  endDate    DateTime
  isClosed   Boolean     @default(false)
  auditItems AuditItem[]
}

enum AuditStatus {
  PENDING
  VERIFIED
  MISSING
  DAMAGED
}

model AuditItem {
  id           String      @id @default(uuid())
  auditCycleId String
  auditCycle   AuditCycle  @relation(fields: [auditCycleId], references: [id])
  assetId      String
  asset        Asset       @relation(fields: [assetId], references: [id])
  status       AuditStatus @default(PENDING)
  notes        String?
  updatedAt    DateTime    @updatedAt
}
